# MindBusiness AI — environment variables
# Copy this file to .env.local for local dev. In production, set these in
# the Vercel project settings instead.

# ── Frontend (Next.js public env) ────────────────────────────────────────────
# Same-origin deployment on Vercel — leave unset and the app will call /api
# directly. Only set this when running the frontend separately from the
# backend (e.g., a Cloudflare Pages frontend pointing at a Railway backend).
# NEXT_PUBLIC_API_URL=https://your-backend.example.com

# ── Backend (Python serverless functions) ────────────────────────────────────

# Google Gemini API key (optional — BYOK is the default model).
# Leave unset for "every user must bring their own key" deployments.
# Get a key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Set to "production" to disable /docs and /redoc.
# ENVIRONMENT=production

# CORS — only used when the frontend is on a different origin. With the
# unified Vercel deployment this is unnecessary (same-origin). If you do
# need it, set a comma-separated allow-list.
# ALLOWED_ORIGINS=https://your-app.vercel.app,https://custom-domain.com

# ── Job queue / KV (Phase 2+: Fire-and-Poll) ─────────────────────────────────
# Upstash Redis REST endpoint. Required for /api/v1/jobs/* endpoints.
# Create one at https://console.upstash.com (free tier is enough) and
# Vercel can also auto-provision via the integration.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
