# Backend API URL — REQUIRED in production builds.
# In production, the build will not silently fall back to localhost; the
# value must be set in your hosting provider's dashboard.

# Local development:
NEXT_PUBLIC_API_URL=http://localhost:8000

# Production (Vercel / Netlify / etc.):
# NEXT_PUBLIC_API_URL=https://your-backend.up.railway.app
