{
    "$schema": "https://openapi.vercel.sh/vercel.json",
    "regions": ["hnd1"],
    "functions": {
        "api/index.py": {
            "maxDuration": 300,
            "memory": 1024,
            "includeFiles": "api/prompts/**"
        }
    },
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/api/index"
        }
    ]
}
