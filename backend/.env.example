# Google Gemini API Key (optional — BYOK is the default model).
# If set, this acts as a fallback when users haven't pasted their own key.
# Leave unset for "every user must bring their own key" deployments.
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Environment — set to "production" in deployment to disable /docs and /redoc.
# ENVIRONMENT=production

# CORS allowed origins (REQUIRED in production).
# Default: localhost dev. Comma-separated. Wildcard "*" disables credentials.
# ALLOWED_ORIGINS=https://your-app.vercel.app,https://custom-domain.com
